# ═══════════════════════════════════════════════════
# AI-PatternWeb Backend — Environment Variables
# ═══════════════════════════════════════════════════
# Bu dosyayı .env olarak kopyalayın ve değerleri doldurun:
# cp .env.example .env

# ── Database ──
DATABASE_URL=postgresql://patternweb:CHANGE_ME@localhost:5432/patternweb

# ── Redis (opsiyonel) ──
REDIS_URL=redis://localhost:6379/0

# ── JWT Authentication ──
# Güçlü bir secret oluşturun: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=CHANGE-THIS-IN-PRODUCTION
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=1440

# ── Google Gemini AI ──
GEMINI_API_KEY=

# ── Ödeme (Iyzico) ──
IYZICO_API_KEY=
IYZICO_SECRET_KEY=
IYZICO_BASE_URL=https://sandbox-api.iyzipay.com

# ── Google OAuth ──
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── App Ayarları ──
ALLOWED_ORIGINS=http://localhost:3000
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=50
FRONTEND_URL=http://localhost:3000

# ── Email (SMTP) ──
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
